{# Ce fichier est rechargé par AJAX #}

{% if chaussettes is empty %}
    <div class="alert alert-warning text-center mt-4">Aucune chaussette ne correspond à votre recherche.</div>
{% else %}

    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        {% for chaussette in chaussettes %}
            <div class="col">
                {# N'oublie pas d'adapter le nom de la route 'app_chaussette_show' si besoin #}
                <a href="{{ path('app_chaussette_show', {'id': chaussette.id}) }}" class="text-decoration-none text-dark">
                    <div class="card h-100 shadow-sm border-0 carte-chaussette">

                        {# --- EN-TÊTE VISUEL (Pour remplacer la photo) --- #}
                        <div class="card-header border-0 text-center py-4 bg-light">
                            <i class="bi bi-layers-fill fs-1 text-secondary"></i>
                            <h5 class="mt-3 mb-0 fw-bold text-dark">
                                {{ chaussette.NomChaussette|default('Chaussette sans nom') }}
                            </h5>
                        </div>

                        {# --- LES INFOS --- #}
                        <div class="card-body text-center d-flex flex-column justify-content-between">
                            <div>
                                <p class="mb-1 small">
                                    <span class="fw-bold text-muted">Type:</span>
                                    {{ chaussette.type ? chaussette.type.NomType : 'Non défini' }}
                                </p>
                                <p class="mb-1 small">
                                    <span class="fw-bold text-muted">Couleur:</span>
                                    {{ chaussette.couleur ? chaussette.couleur.NomCouleur : 'Non définie' }}
                                </p>
                                <p class="mb-3 small">
                                    <span class="fw-bold text-muted">Taille:</span>
                                    {{ chaussette.taille|default('?') }}
                                </p>
                            </div>

                            {# --- BADGE ÉTAT (Paire ou Orpheline) --- #}
                            <div class="mt-2">
                                {% if chaussette.couple %}
                                    <span class="badge bg-success rounded-pill px-3 py-2 w-100">
                                        <i class="bi bi-check-circle-fill me-1"></i> Paire complète
                                    </span>
                                {% else %}
                                    <span class="badge bg-warning text-dark rounded-pill px-3 py-2 w-100">
                                        <i class="bi bi-exclamation-circle-fill me-1"></i> Orpheline
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                    </div>
                </a>
            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    <div class="d-flex justify-content-center mt-5">
        {{ knp_pagination_render(chaussettes) }}
    </div>

{% endif %}
