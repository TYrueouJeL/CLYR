{# Partial rechargé par AJAX — dark theme #}

{% if chaussettes is empty %}

    <div class="results-empty">
        <div class="results-empty-icon">🔍</div>
        <p class="results-empty-title">Aucune chaussette trouvée</p>
        <p class="results-empty-sub">Essayez de modifier vos filtres ou <a href="{{ path('app_chaussette') }}">réinitialisez la recherche</a>.</p>
    </div>

{% else %}

    <div class="results-meta">
        {{ chaussettes.totalItemCount }} chaussette{{ chaussettes.totalItemCount > 1 ? 's' : '' }} trouvée{{ chaussettes.totalItemCount > 1 ? 's' : '' }}
    </div>

    <div class="sock-grid">
        {% for chaussette in chaussettes %}
            <div class="sock-tile">

                {# Visuel coloré selon la couleur #}
                {% set couleurNom = chaussette.couleur ? chaussette.couleur.NomCouleur|lower : '' %}
                {% set couleurClass =
                    'rouge' in couleurNom or 'red' in couleurNom ? 'sock-tile-rouge' :
                    'bleu' in couleurNom or 'blue' in couleurNom or 'marine' in couleurNom ? 'sock-tile-bleu' :
                    'vert' in couleurNom or 'green' in couleurNom ? 'sock-tile-vert' :
                    'violet' in couleurNom or 'purple' in couleurNom ? 'sock-tile-violet' :
                    'jaune' in couleurNom or 'yellow' in couleurNom ? 'sock-tile-jaune' :
                    'noir' in couleurNom or 'black' in couleurNom ? 'sock-tile-noir' :
                    'blanc' in couleurNom or 'white' in couleurNom ? 'sock-tile-blanc' :
                    'rose' in couleurNom or 'pink' in couleurNom ? 'sock-tile-rose' :
                    'sock-tile-default'
                %}
                <div class="sock-tile-visual {{ couleurClass }}">
                    <span class="sock-tile-emoji">🧦</span>
                    <div class="sock-tile-status {{ chaussette.couple ? 'status-couple' : 'status-orphan' }}">
                        {{ chaussette.couple ? '❤️ En couple' : '🧦 Orpheline' }}
                    </div>
                </div>

                <div class="sock-tile-body">
                    <div class="sock-tile-name">{{ chaussette.NomChaussette|default('Chaussette sans nom') }}</div>

                    <div class="sock-tile-details">
                        {% if chaussette.type %}
                            <span class="sock-detail-pill">{{ chaussette.type.NomType }}</span>
                        {% endif %}
                        {% if chaussette.couleur %}
                            <span class="sock-detail-pill">{{ chaussette.couleur.NomCouleur }}</span>
                        {% endif %}
                        {% if chaussette.taille %}
                            <span class="sock-detail-pill">T.{{ chaussette.taille }}</span>
                        {% endif %}
                    </div>

                    {% if chaussette.Commentaire %}
                        <p class="sock-tile-comment">{{ chaussette.Commentaire|slice(0, 80) }}{% if chaussette.Commentaire|length > 80 %}…{% endif %}</p>
                    {% endif %}

                    {% if chaussette.dateCreation %}
                        <div class="sock-tile-date">
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            Signalée le {{ chaussette.dateCreation|date('d/m/Y') }}
                        </div>
                    {% endif %}
                </div>

                <div class="sock-tile-actions">
                    <button class="sock-action-like" title="J'ai le binôme !">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        Binôme
                    </button>
                    <a href="{{ path('app_chaussette_show', {id: chaussette.id}) }}" class="sock-action-msg" title="Voir la fiche">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </a>
                </div>

            </div>
        {% endfor %}
    </div>

    {# Pagination #}
    <div class="pagination-wrap">
        {{ knp_pagination_render(chaussettes) }}
    </div>

{% endif %}

