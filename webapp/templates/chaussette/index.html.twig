{% extends 'base.html.twig' %}

{% block title %}CLYR — Explorer les chaussettes{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        const form = document.getElementById('searchForm');
        const zone = document.getElementById('resultats-zone');
        if (!form || !zone) return;

        function doSearch() {
            const url = form.dataset.url + '?' + new URLSearchParams(new FormData(form)).toString() + '&ajax=1';
            zone.classList.add('loading');
            fetch(url)
                .then(r => r.text())
                .then(html => { zone.innerHTML = html; zone.classList.remove('loading'); })
                .catch(() => zone.classList.remove('loading'));
        }

        form.querySelectorAll('input, select').forEach(el => {
            el.addEventListener('input', () => clearTimeout(el._t) || (el._t = setTimeout(doSearch, 350)));
            el.addEventListener('change', doSearch);
        });
    });
    </script>
{% endblock %}

{% block body %}

{% include 'layout/_navbar.html.twig' with { active: 'chaussette' } %}

<div class="layout">

    {% include 'layout/_sidebar.html.twig' with { active: 'chaussette' } %}

    <main class="explore-main">

        {# Header #}
        <div class="explore-header">
            <div>
                <h1 class="explore-title">Explorer</h1>
                <p class="explore-sub">Trouvez la chaussette qui vous ressemble</p>
            </div>
            <a href="{{ path('app_chaussette_create') }}" class="btn-primary-grad">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Signaler une chaussette
            </a>
        </div>

        {# Filtres #}
        <div class="filter-card" id="filterCard">
            <div class="filter-card-header" onclick="toggleFilters()">
                <div style="display:flex;align-items:center;gap:8px;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
                    <span style="font-weight:600;font-size:.9rem;">Filtres de recherche</span>
                </div>
                <svg id="filterChevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="transition:transform .25s;"><polyline points="6 9 12 15 18 9"/></svg>
            </div>

            <form id="searchForm" data-url="{{ path('app_chaussette') }}" class="filter-grid" id="filterGrid">

                <div class="filter-field">
                    <label class="filter-label">Type</label>
                    <div class="filter-input-wrap">
                        <svg class="filter-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        <input class="filter-input" list="dl_types" name="type" placeholder="Ex: Socquette…">
                        <datalist id="dl_types">
                            {% for t in liste_types %}
                                {% if t.NomType is defined %}<option value="{{ t.NomType }}">{% endif %}
                            {% endfor %}
                        </datalist>
                    </div>
                </div>

                <div class="filter-field">
                    <label class="filter-label">Couleur</label>
                    <div class="filter-input-wrap">
                        <svg class="filter-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>
                        <input class="filter-input" list="dl_couleurs" name="couleur" placeholder="Ex: Rouge…">
                        <datalist id="dl_couleurs">
                            {% for c in liste_couleurs %}
                                {% if c.NomCouleur is defined %}<option value="{{ c.NomCouleur }}">{% endif %}
                            {% endfor %}
                        </datalist>
                    </div>
                </div>

                <div class="filter-field">
                    <label class="filter-label">Taille</label>
                    <div class="filter-input-wrap">
                        <svg class="filter-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                        <input class="filter-input" list="dl_tailles" name="taille" placeholder="Ex: 42…">
                        <datalist id="dl_tailles">
                            {% for taille in liste_tailles %}
                                <option value="{{ taille }}">
                            {% endfor %}
                        </datalist>
                    </div>
                </div>

                <div class="filter-field">
                    <label class="filter-label">État</label>
                    <div class="filter-input-wrap">
                        <svg class="filter-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        <select class="filter-input filter-select" name="couple">
                            <option value="">Toutes</option>
                            <option value="1">En couple ❤️</option>
                            <option value="0">Orpheline 🧦</option>
                        </select>
                    </div>
                </div>

                <div class="filter-field">
                    <label class="filter-label">Date d'ajout</label>
                    <div class="filter-input-wrap">
                        <svg class="filter-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        <input class="filter-input" type="date" name="date_creation">
                    </div>
                </div>

            </form>
        </div>

        {# Résultats #}
        <div id="resultats-zone">
            {% include 'chaussette/_liste_chaussettes.html.twig' %}
        </div>

    </main>

    <aside class="sidebar-right">
        <div class="right-card">
            <div class="section-title">Recherches populaires</div>
            <div class="trend-list">
                <div class="trend-item"><span class="trend-tag">Chaussette Nike</span><span class="trend-count">342</span></div>
                <div class="trend-item"><span class="trend-tag">Rayée rouge T.42</span><span class="trend-count">218</span></div>
                <div class="trend-item"><span class="trend-tag">Socquette blanche</span><span class="trend-count">197</span></div>
                <div class="trend-item"><span class="trend-tag">Montante laine</span><span class="trend-count">134</span></div>
                <div class="trend-item"><span class="trend-tag">Chaussette de Noël</span><span class="trend-count">98</span></div>
            </div>
        </div>
        <div class="right-card">
            <div class="section-title">Statistiques</div>
            <div style="display:flex;flex-direction:column;gap:10px;font-size:.82rem;color:var(--text-2);">
                <div style="display:flex;justify-content:space-between;"><span>Total catalogue</span><strong style="color:var(--text);">18 472</strong></div>
                <div style="display:flex;justify-content:space-between;"><span>Orphelines</span><strong style="color:#FF4458;">11 238</strong></div>
                <div style="display:flex;justify-content:space-between;"><span>En couple</span><strong style="color:#45b87c;">7 234</strong></div>
                <div style="display:flex;justify-content:space-between;"><span>Ajoutées ce mois</span><strong style="color:var(--accent2);">+847</strong></div>
            </div>
        </div>
        <div class="sidebar-footer">
            <a href="#">À propos</a> · <a href="#">Aide</a> · <a href="#">CGU</a><br>
            © 2026 CLYR
        </div>
    </aside>

</div>


<script>
function toggleFilters() {
    const grid = document.getElementById('searchForm');
    const chevron = document.getElementById('filterChevron');
    grid.classList.toggle('collapsed');
    chevron.style.transform = grid.classList.contains('collapsed') ? 'rotate(-90deg)' : '';
}
</script>

{% endblock %}
