{% extends 'base.html.twig' %}

{% block title %}CLYR — Modifier : {{ chaussette.NomChaussette|default('Chaussette') }}{% endblock %}

{% block body %}

{% include 'layout/_navbar.html.twig' with { active: 'chaussette' } %}

<div class="layout">

    {% include 'layout/_sidebar.html.twig' with { active: 'chaussette' } %}

    <main class="explore-main">

        <div class="explore-header">
            <div>
                <h1 class="explore-title">Modifier la chaussette</h1>
                <p class="explore-sub">{{ chaussette.NomChaussette|default('Sans nom') }}</p>
            </div>
            <a href="{{ path('app_chaussette_show', {id: chaussette.id}) }}" class="btn-ghost-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Retour à la fiche
            </a>
        </div>

        <div class="form-card">

            {{ form_start(form, { attr: { class: 'sock-form', id: 'form-edit-chaussette', novalidate: 'novalidate' } }) }}

            {# ── Identification ── #}
            <div class="form-section">
                <div class="form-section-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                    Identification
                </div>
                <div class="sock-field">
                    {{ form_label(form.NomChaussette, 'Nom', { label_attr: { class: 'sock-label' } }) }}
                    {{ form_widget(form.NomChaussette, { attr: { class: 'sock-input' } }) }}
                    {% for error in form.NomChaussette.vars.errors %}
                        <div class="sock-error">{{ error.message }}</div>
                    {% endfor %}
                </div>
            </div>

            {# ── Caractéristiques ── #}
            <div class="form-section">
                <div class="form-section-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                    Caractéristiques
                </div>
                <div class="sock-row">
                    <div class="sock-field">
                        {{ form_label(form.type, 'Type', { label_attr: { class: 'sock-label' } }) }}
                        {{ form_widget(form.type, { attr: { class: 'sock-input sock-select' } }) }}
                    </div>
                    <div class="sock-field">
                        {{ form_label(form.couleur, 'Couleur', { label_attr: { class: 'sock-label' } }) }}
                        {{ form_widget(form.couleur, { attr: { class: 'sock-input sock-select' } }) }}
                    </div>
                </div>
                <div class="sock-row">
                    <div class="sock-field">
                        {{ form_label(form.taille, 'Taille', { label_attr: { class: 'sock-label' } }) }}
                        {{ form_widget(form.taille, { attr: { class: 'sock-input', list: 'list_tailles' } }) }}
                        <datalist id="list_tailles">
                            {% for item in liste_tailles %}<option value="{{ item }}">{% endfor %}
                        </datalist>
                    </div>
                    <div class="sock-field sock-field-switch">
                        <span class="sock-label">Statut</span>
                        <label class="sock-switch-wrap">
                            {{ form_widget(form.couple, { attr: { class: 'sock-switch-input' } }) }}
                            <span class="sock-switch-track">
                                <span class="sock-switch-thumb"></span>
                            </span>
                            <span class="sock-switch-label">Paire complète ?</span>
                        </label>
                    </div>
                </div>
            </div>

            {# ── Historique ── #}
            <div class="form-section">
                <div class="form-section-title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                    Historique & Notes
                </div>
                <div class="sock-row">
                    <div class="sock-field">
                        {{ form_label(form.dateCreation, 'Date de signalement', { label_attr: { class: 'sock-label' } }) }}
                        {{ form_widget(form.dateCreation, { attr: { class: 'sock-input' } }) }}
                    </div>
                </div>
                <div class="sock-field">
                    {{ form_label(form.Commentaire, 'Commentaire', { label_attr: { class: 'sock-label' } }) }}
                    {{ form_widget(form.Commentaire, { attr: { class: 'sock-input sock-textarea', rows: 3 } }) }}
                </div>
            </div>

            {# ── Actions ── #}
            <div class="form-actions">
                <button type="submit" class="btn-primary-grad">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    Enregistrer les modifications
                </button>
                <a href="{{ path('app_chaussette_show', {id: chaussette.id}) }}" class="btn-outline-cancel">Annuler</a>

                {% if is_granted('ROLE_ADMIN') %}
                    <form method="post" action="{{ path('app_chaussette_delete', {id: chaussette.id}) }}" style="margin-left:auto;" onsubmit="return confirm('Supprimer définitivement cette chaussette ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ chaussette.id) }}">
                        <button type="submit" class="btn-danger-outline">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                            Supprimer
                        </button>
                    </form>
                {% endif %}
            </div>

            <div class="d-none">{{ form_rest(form) }}</div>
            {{ form_end(form) }}

        </div>

    </main>

    <aside class="sidebar-right">
        <div class="right-card">
            <div class="section-title">Aperçu actuel</div>
            {% set couleurNom = chaussette.couleur ? chaussette.couleur.NomCouleur|lower : '' %}
            {% set couleurClass =
                'rouge' in couleurNom or 'red' in couleurNom ? 'sock-tile-rouge' :
                'bleu' in couleurNom or 'blue' in couleurNom or 'marine' in couleurNom ? 'sock-tile-bleu' :
                'vert' in couleurNom or 'green' in couleurNom ? 'sock-tile-vert' :
                'violet' in couleurNom or 'purple' in couleurNom ? 'sock-tile-violet' :
                'jaune' in couleurNom or 'yellow' in couleurNom ? 'sock-tile-jaune' :
                'noir' in couleurNom or 'black' in couleurNom ? 'sock-tile-noir' :
                'blanc' in couleurNom or 'white' in couleurNom ? 'sock-tile-blanc' :
                'rose' in couleurNom or 'pink' in couleurNom ? 'sock-tile-rose' :
                'sock-tile-default'
            %}
            <div class="sock-tile" style="max-width:180px;margin:0 auto;">
                <div class="sock-tile-visual {{ couleurClass }}">
                    <span class="sock-tile-emoji">🧦</span>
                    <div class="sock-tile-status {{ chaussette.couple ? 'status-couple' : 'status-orphan' }}">
                        {{ chaussette.couple ? '❤️' : '🧦' }}
                    </div>
                </div>
                <div class="sock-tile-body">
                    <div class="sock-tile-name">{{ chaussette.NomChaussette|default('Sans nom') }}</div>
                    <div class="sock-tile-details">
                        {% if chaussette.type %}<span class="sock-detail-pill">{{ chaussette.type.NomType }}</span>{% endif %}
                        {% if chaussette.couleur %}<span class="sock-detail-pill">{{ chaussette.couleur.NomCouleur }}</span>{% endif %}
                        {% if chaussette.taille %}<span class="sock-detail-pill">T.{{ chaussette.taille }}</span>{% endif %}
                    </div>
                </div>
            </div>
        </div>
        <div class="sidebar-footer">
            <a href="#">À propos</a> · <a href="#">Aide</a> · <a href="#">CGU</a><br>
            © 2026 CLYR
        </div>
    </aside>

</div>

{% endblock %}
