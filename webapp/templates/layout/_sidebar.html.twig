{# ── Shared left sidebar ────────────────────────────
   Usage: {% include 'layout/_sidebar.html.twig' with { active: 'home' } %}
──────────────────────────────────────────────────── #}
<aside class="sidebar-left">

    <div class="sidebar-profile">
        <div class="sidebar-avatar">
            {% if app.user %}{{ app.user.email|first|upper }}{% else %}?{% endif %}
        </div>
        <div>
            <div class="sidebar-name">
                {% if app.user %}{{ app.user.email }}{% else %}Visiteur{% endif %}
            </div>
            <div class="sidebar-handle">
                {% if app.user %}@{{ app.user.email|split('@')|first }}{% else %}<a href="{{ path('app_login') }}" style="color:var(--accent);text-decoration:none;">Se connecter</a>{% endif %}
            </div>
        </div>
    </div>

    <div class="sidebar-divider"></div>

    <a href="{{ path('app_home') }}" class="sidebar-item {{ active == 'home' ? 'active' : '' }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span>Fil d'actualité</span>
    </a>
    <a href="{{ path('app_chaussette') }}" class="sidebar-item {{ active == 'chaussette' ? 'active' : '' }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span>Explorer</span>
    </a>
    <button class="sidebar-item {{ active == 'mes-chaussettes' ? 'active' : '' }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>
        <span>Mes chaussettes</span>
        <span class="item-badge">2</span>
    </button>
    <a href="{{ path('app_match') }}" class="sidebar-item {{ active == 'match' ? 'active' : '' }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <span>SockMatch ❤️</span>
    </a>
    <button class="sidebar-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span>Classement</span>
    </button>

    <div class="sidebar-divider"></div>
    <div class="sidebar-section-label">Mes groupes</div>

    <button class="sidebar-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span>Chaussettes de sport</span>
    </button>
    <button class="sidebar-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span>Chaussettes de Noël</span>
    </button>

    <div class="sidebar-divider"></div>

    <button class="sidebar-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
        <span>Paramètres</span>
    </button>

    {% if app.user %}
    <a href="{{ path('app_logout') }}" class="sidebar-item" style="margin-top:auto;color:#e17055;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        <span>Déconnexion</span>
    </a>
    {% endif %}

</aside>
