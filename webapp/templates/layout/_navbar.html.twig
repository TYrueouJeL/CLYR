{# ── Shared dark topbar ─────────────────────────────
   Usage: {% include 'layout/_navbar.html.twig' with { active: 'home' } %}
   active: 'home' | 'chaussette' | 'match' | 'community'
──────────────────────────────────────────────────── #}
<header class="topbar">

    <div class="topbar-brand">
        <span class="brand-logo">🧦 CLYR<sup>beta</sup></span>
    </div>

    <div class="topbar-search">
        <div class="search-wrap">
            <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" placeholder="Rechercher une chaussette…">
        </div>
    </div>

    <nav class="topbar-nav">
        <a href="{{ path('app_home') }}" class="topnav-btn {{ active == 'home' ? 'active' : '' }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            <span>Accueil</span>
        </a>
        <a href="{{ path('app_chaussette') }}" class="topnav-btn {{ active == 'chaussette' ? 'active' : '' }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <span>Explorer</span>
        </a>
        <a href="{{ path('app_match') }}" class="topnav-btn {{ active == 'match' ? 'active' : '' }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            <span>SockMatch</span>
        </a>
        <button class="topnav-btn {{ active == 'community' ? 'active' : '' }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span>Communauté</span>
        </button>
    </nav>

    <div class="topbar-user">
        <button class="top-icon-btn" title="Notifications">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <span class="badge">3</span>
        </button>
        <button class="top-icon-btn" title="Messages">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        </button>
        {% if app.user %}
            <a href="{{ path('app_logout') }}" class="avatar-sm" title="Se déconnecter">{{ app.user.email|first|upper }}</a>
        {% else %}
            <a href="{{ path('app_login') }}" class="avatar-sm" title="Se connecter">?</a>
        {% endif %}
    </div>

</header>
