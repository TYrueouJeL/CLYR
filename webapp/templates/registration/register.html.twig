{% extends 'base.html.twig' %}

{% block title %}CLYR — Créer un compte{% endblock %}

{% block body %}
<div class="auth-page">

    <div class="auth-bg">
        <div class="auth-bg-orb orb-1"></div>
        <div class="auth-bg-orb orb-2"></div>
        <div class="auth-bg-orb orb-3"></div>
    </div>

    <div class="auth-card">

        <a href="{{ path('app_home') }}" class="auth-logo">
            <span class="auth-logo-emoji">🧦</span>
            <span class="auth-logo-name">CLYR</span>
        </a>

        <h1 class="auth-title">Rejoins la communauté</h1>
        <p class="auth-sub">Des milliers de chaussettes n'attendent que toi</p>

        {# Erreurs globales du formulaire #}
        {% for error in registrationForm.vars.errors %}
            <div class="auth-alert">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                {{ error.message }}
            </div>
        {% endfor %}

        {{ form_start(registrationForm, { attr: { class: 'auth-form', novalidate: 'novalidate' } }) }}

            {# Email #}
            <div class="auth-field">
                <label class="auth-label" for="{{ registrationForm.email.vars.id }}">Adresse e-mail</label>
                <div class="auth-input-wrap">
                    <svg class="auth-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    {{ form_widget(registrationForm.email, { attr: { class: 'auth-input', placeholder: 'ton@email.fr' } }) }}
                </div>
                {% for error in registrationForm.email.vars.errors %}
                    <div class="auth-field-error">{{ error.message }}</div>
                {% endfor %}
            </div>

            {# Mot de passe #}
            <div class="auth-field">
                <label class="auth-label" for="{{ registrationForm.plainPassword.vars.id }}">Mot de passe</label>
                <div class="auth-input-wrap">
                    <svg class="auth-input-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    {{ form_widget(registrationForm.plainPassword, { attr: { class: 'auth-input', placeholder: 'Minimum 6 caractères' } }) }}
                    <button type="button" class="auth-toggle-pw" onclick="togglePassword(this)" tabindex="-1">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </button>
                </div>
                <div class="pw-strength" id="pwStrength">
                    <div class="pw-bar"></div><div class="pw-bar"></div><div class="pw-bar"></div><div class="pw-bar"></div>
                </div>
                {% for error in registrationForm.plainPassword.vars.errors %}
                    <div class="auth-field-error">{{ error.message }}</div>
                {% endfor %}
            </div>

            {# CGU #}
            <div class="auth-checkbox">
                {{ form_widget(registrationForm.agreeTerms, { attr: { class: 'auth-check-input', id: 'agreeTerms' } }) }}
                <label class="auth-check-label" for="agreeTerms">
                    J'accepte les <a href="#">Conditions d'utilisation</a> et la <a href="#">Politique de confidentialité</a> de CLYR
                </label>
            </div>
            {% for error in registrationForm.agreeTerms.vars.errors %}
                <div class="auth-field-error" style="margin-top:-8px;">{{ error.message }}</div>
            {% endfor %}

            <button type="submit" class="auth-submit">
                Créer mon compte
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>

        {{ form_end(registrationForm) }}

        <div class="auth-divider"><span>ou</span></div>

        <div class="auth-footer">
            Déjà un compte ?
            <a href="{{ path('app_login') }}">Se connecter</a>
        </div>

    </div>

</div>


<script>
function togglePassword(btn) {
    const input = btn.closest('.auth-input-wrap').querySelector('input');
    input.type = input.type === 'password' ? 'text' : 'password';
}

// Password strength indicator
const pwInput = document.querySelector('input[type="password"]');
const bars = document.querySelectorAll('.pw-bar');
if (pwInput) {
    pwInput.addEventListener('input', function() {
        const v = this.value, len = v.length;
        let score = 0;
        if (len >= 6)  score++;
        if (len >= 10) score++;
        if (/[A-Z]/.test(v) && /[0-9]/.test(v)) score++;
        if (/[^A-Za-z0-9]/.test(v)) score++;

        bars.forEach((b, i) => {
            b.className = 'pw-bar';
            if (i < score) {
                b.classList.add(score <= 1 ? 'weak' : score <= 2 ? 'medium' : 'strong');
            }
        });
    });
}
</script>

{% endblock %}
