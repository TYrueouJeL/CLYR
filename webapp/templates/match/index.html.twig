        </button>
        <button class="sm-action-btn sm-btn-like" onclick="swipeCard('right')" title="Like">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1ECC72" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </button>
        <button class="sm-action-btn sm-btn-boost" onclick="boostCard()" title="Boost">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#9B59F7" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
