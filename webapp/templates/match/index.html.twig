            <button class="sm-reload-btn" onclick="reloadDeck()">Recharger</button>
        </div>

        <div class="sm-deck" id="smDeck">

            {# ── Carte 5 (fond du stack) ── #}
            <div class="sm-card" data-name="Chaussette Noire" data-id="5">
                <div class="sm-card-bg" style="background:linear-gradient(160deg,#2d3436 0%,#636e72 100%);">
                    <span class="sm-card-emoji">🧦</span>
                </div>
                <div class="sm-label sm-label-like">LIKE</div>
                <div class="sm-label sm-label-nope">NOPE</div>
                <div class="sm-label sm-label-super">SUPER<br>LIKE</div>
                <div class="sm-card-overlay">
                    <div class="sm-card-info">
                        <div class="sm-card-name">
                            Chaussette Noire
                            <span class="sm-card-age">Taille 44</span>
                        </div>
                        <div class="sm-card-meta">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            2 km · Dim · Sport
                        </div>
                        <div class="sm-card-bio">Chaussette noire côtelée, habituée aux matchs de foot. Un peu odorante, désolé 😅</div>
                        <div class="sm-card-tags">
                            <span class="sm-tag sm-tag-lost">Perdue 4j</span>
                            <span class="sm-tag">Lyon 69003</span>
                        </div>
                    </div>
                    <button class="sm-info-btn" onclick="event.stopPropagation()">
