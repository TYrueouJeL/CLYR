{% extends 'base.html.twig' %}

{% block title %}SockMatch — Trouve ton binôme{% endblock %}

{% block body_class %}match-page{% endblock %}

{% block body %}
<div class="sm-app">

    {# ══════════════ TOP NAV ══════════════ #}
