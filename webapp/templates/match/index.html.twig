            <h2 class="sm-match-title">MATCH !</h2>
            <p class="sm-match-sub">Tu as swipé à droite en même temps 🧦❤️🧦</p>
            <div class="sm-match-avatars">
                <div class="sm-match-av sm-match-av-you">M</div>
                <div class="sm-match-av sm-match-av-them" id="matchAvThem">🧦</div>
            </div>
            <p class="sm-match-names" id="matchNames">Vous &amp; Rougette</p>
            <button class="sm-match-msg-btn" onclick="closeMatch()">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                Envoyer un message
            </button>
            <button class="sm-match-skip-btn" onclick="closeMatch()">Continuer à swiper</button>
        </div>
    </div>

</div>{# /sm-app #}




<script>
(function() {
    'use strict';

    const THRESHOLD = 80;
    let isDragging = false;
    let startX = 0, startY = 0;
    let dx = 0, dy = 0;
    let topCard = null;
    let history = [];
    let likes = 0, nopes = 0;

    function getDeck() { return document.getElementById('smDeck'); }

    function getTopCard() {
        const cards = getDeck().querySelectorAll('.sm-card:not([style*="display: none"])');
        return cards.length ? cards[cards.length - 1] : null;
    }

    function updateCardStack() {
        const cards = Array.from(getDeck().querySelectorAll('.sm-card:not([style*="display: none"])'));
        // Réinitialise les nth-child transforms en retirant le style inline
        cards.forEach((c, i) => {
            if (i < cards.length - 1) {
                // pas la carte du dessus
                c.style.transition = 'transform .3s ease';
                c.style.transform = '';
                setTimeout(() => { c.style.transition = ''; }, 320);
            }
        });

        // Si plus de cartes → empty state
        if (cards.length === 0) {
            getDeck().style.display = 'none';
            document.getElementById('emptyState').classList.add('visible');
        }
    }

    /* ── Swipe programmatique ── */
    window.swipeCard = function(dir) {
        const card = getTopCard();
        if (!card) return;

        // Labels
        const likeEl  = card.querySelector('.sm-label-like');
        const nopeEl  = card.querySelector('.sm-label-nope');
        const superEl = card.querySelector('.sm-label-super');
        if (dir === 'right') { likeEl.style.opacity  = 1; likes++; }
        if (dir === 'left')  { nopeEl.style.opacity  = 1; nopes++; }
        if (dir === 'up')    { superEl.style.opacity = 1; }

        const cls = dir === 'right' ? 'sm-fly-right'
                  : dir === 'left'  ? 'sm-fly-left'
                  :                   'sm-fly-up';

        card.style.transition = 'none';
        card.classList.add(cls);
        history.push({ card, dir });

        card.addEventListener('animationend', () => {
            card.style.display = 'none';
            card.classList.remove(cls);
            updateCardStack();

            if (dir === 'right' && Math.random() < 0.4) {
                const name = card.dataset.name || 'cette chaussette';
                setTimeout(() => triggerMatch(name), 350);
            }
        }, { once: true });
    };

    /* ── Rewind ── */
    window.rewindCard = function() {
        if (!history.length) return;
        const { card, dir } = history.pop();
        const cls = dir === 'right' ? 'sm-fly-right'
                  : dir === 'left'  ? 'sm-fly-left'
                  :                   'sm-fly-up';

        card.style.display = '';
        card.classList.remove(cls);
        card.style.transform = '';
        card.querySelectorAll('.sm-label').forEach(l => l.style.opacity = 0);

        if (dir === 'right' && likes > 0) likes--;
        if (dir === 'left'  && nopes > 0) nopes--;

        getDeck().style.display = '';
        document.getElementById('emptyState').classList.remove('visible');

        updateCardStack();
    };

    /* ── Boost ── */
    window.boostCard = function() {
        const card = getTopCard();
        if (!card) return;
        card.classList.remove('sm-boosting');
        void card.offsetWidth; // reflow
        card.classList.add('sm-boosting');
    };

    /* ── Reload ── */
    window.reloadDeck = function() {
        getDeck().querySelectorAll('.sm-card').forEach(c => {
            c.style.display = '';
            c.style.transform = '';
            c.querySelectorAll('.sm-label').forEach(l => l.style.opacity = 0);
        });
        history = []; likes = 0; nopes = 0;
        getDeck().style.display = '';
        document.getElementById('emptyState').classList.remove('visible');
        updateCardStack();
    };

    /* ── Match overlay ── */
    function triggerMatch(name) {
        document.getElementById('matchNames').textContent = 'Vous & ' + name;
        document.getElementById('matchOverlay').classList.add('visible');
    }
    window.closeMatch = function() {
        document.getElementById('matchOverlay').classList.remove('visible');
    };

    /* ════════════════════════════════
       DRAG / SWIPE GESTURE
    ════════════════════════════════ */
    function clientXY(e) {
        if (e.touches) return { x: e.touches[0].clientX, y: e.touches[0].clientY };
        return { x: e.clientX, y: e.clientY };
    }

    function onDown(e) {
        const card = getTopCard();
        if (!card) return;
        // Only start drag if event target is on the top card
        if (!card.contains(e.target)) return;
        // Don't drag on info button
        if (e.target.closest('.sm-info-btn')) return;

        isDragging = true;
        topCard = card;
        const { x, y } = clientXY(e);
        startX = x; startY = y;
        topCard.style.transition = 'none';
        topCard.style.zIndex = 50;
    }

    function onMove(e) {
        if (!isDragging || !topCard) return;
        e.preventDefault && e.preventDefault();

        const { x, y } = clientXY(e);
        dx = x - startX;
        dy = y - startY;

        const rot = dx * 0.07;
        topCard.style.transform = `translate(${dx}px, ${dy}px) rotate(${rot}deg)`;

        // Labels
        const t = THRESHOLD;
        const likeEl  = topCard.querySelector('.sm-label-like');
        const nopeEl  = topCard.querySelector('.sm-label-nope');
        const superEl = topCard.querySelector('.sm-label-super');

        likeEl.style.opacity  = dx > 0  ? Math.min(dx / t, 1)  : 0;
        nopeEl.style.opacity  = dx < 0  ? Math.min(-dx / t, 1) : 0;
        superEl.style.opacity = dy < -40 ? Math.min(-dy / (t * 1.5), 1) : 0;
    }

    function onUp() {
        if (!isDragging || !topCard) return;
        isDragging = false;
        topCard.style.zIndex = '';

        if (dx > THRESHOLD)          { swipeCard('right'); }
        else if (dx < -THRESHOLD)    { swipeCard('left');  }
        else if (dy < -THRESHOLD * 1.4) { swipeCard('up'); }
        else {
            // Snap back
            topCard.style.transition = 'transform .4s cubic-bezier(.175,.885,.32,1.275)';
            topCard.style.transform  = '';
            topCard.querySelectorAll('.sm-label').forEach(l => l.style.opacity = 0);
            setTimeout(() => { if (topCard) topCard.style.transition = ''; }, 420);
        }

        dx = 0; dy = 0; topCard = null;
    }

    // Mouse
    document.addEventListener('mousedown', onDown);
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup',   onUp);
    // Touch
    document.addEventListener('touchstart', onDown, { passive: true });
    document.addEventListener('touchmove',  onMove, { passive: false });
    document.addEventListener('touchend',   onUp);

    // Keyboard
    document.addEventListener('keydown', e => {
        if (e.key === 'ArrowRight') swipeCard('right');
        if (e.key === 'ArrowLeft')  swipeCard('left');
        if (e.key === 'ArrowUp')    swipeCard('up');
        if (e.key.toLowerCase() === 'z') rewindCard();
    });

})();
</script>

{% endblock %}
