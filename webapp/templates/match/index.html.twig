        <button class="sm-nav-btn">
            <div class="sm-avatar">M</div>
        </button>

        <div class="sm-brand">
            <span class="sm-brand-emoji">🧦</span>
            <span class="sm-brand-name">SockMatch</span>
        </div>

        <div class="sm-nav-right">
            <button class="sm-nav-btn">
